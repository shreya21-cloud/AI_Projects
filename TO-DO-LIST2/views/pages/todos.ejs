<%- include('../partials/header') %>

<div class="glass-card" style="max-width: 600px;">
  <h2>My To-Do List</h2>
  
  <form action="/add" method="POST" class="todo-form">
    <input type="text" name="text" placeholder="What needs to be done?" required autofocus>
    <button type="submit" class="btn btn-primary">Add Task</button>
  </form>

  <% if (todos && todos.length > 0) { %>
    <ul class="todo-list">
      <% todos.forEach(todo => { %>
        <li class="todo-item <%= todo.completed ? 'completed' : '' %>">
          <div class="todo-content">
            <form action="/toggle/<%= todo.id %>" method="POST" class="toggle-form">
              <input type="checkbox" onchange="this.form.submit()" <%= todo.completed ? 'checked' : '' %>>
            </form>
            <span><%= todo.text %></span>
          </div>
          <div class="todo-actions">
            <form action="/delete/<%= todo.id %>" method="POST" class="delete-form">
              <button type="submit" class="btn-icon" title="Delete Task">🗑️</button>
            </form>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } else { %>
    <p class="text-center" style="opacity: 0.6; margin-top: 2rem;">No tasks yet. Add one above!</p>
  <% } %>
</div>

<%- include('../partials/footer') %>
